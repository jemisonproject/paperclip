# ---------------------------------------------------------------
# Paperclip + Tailscale environment variables
# ---------------------------------------------------------------
# Copy this file to .env on the NAS (in the same folder as
# docker-compose.yml) and fill in real values. Never commit .env.
# ---------------------------------------------------------------

# ---- Tailscale ------------------------------------------------
# Generate a reusable auth key at:
#   https://login.tailscale.com/admin/settings/keys
# - Reusable: yes (so re-creating the container doesn't need a new key)
# - Ephemeral: no (we want a stable device)
# - Tags: tag:paperclip (define this tag in your tailnet ACL first)
TS_AUTHKEY=tskey-auth-REPLACE-WITH-YOUR-KEY

# ---- Paperclip ------------------------------------------------
# Public URL Paperclip uses for invite / login links. Set this to
# the Tailscale MagicDNS hostname Paperclip ends up at — you can
# get it after the first `docker compose up` by running:
#   docker exec paperclip-tailscale tailscale status
# It will look like: paperclip.tail-xxxx.ts.net
PAPERCLIP_PUBLIC_URL=https://paperclip.your-tailnet.ts.net

# Random secret for signing sessions/cookies. Generate with:
#   openssl rand -hex 32
PAPERCLIP_SECRET=replace-with-32-byte-random-hex

# The first account that claims the admin invite. Use a real email
# you can receive mail at if Paperclip sends invite confirmations.
PAPERCLIP_ADMIN_EMAIL=juandelgadocarp@gmail.com

# Optional: comma-separated list of email domains allowed to sign up.
# Even though the URL is only reachable on the tailnet, leaving this
# unset means any tailnet member could sign up. With three known
# teammates, invite-only signup from the Paperclip admin UI is enough.
# PAPERCLIP_ALLOWED_EMAIL_DOMAINS=koiomi.com

# ---------------------------------------------------------------
# Agent LLM credentials — DO NOT put a team-wide key here.
# Each teammate sets their own Anthropic key inside Paperclip's UI
# on the agents they own, so usage bills against their own subscription.
# ---------------------------------------------------------------
# ANTHROPIC_API_KEY=  (intentionally left blank — set per-agent in UI)
